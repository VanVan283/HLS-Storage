# HLS VIDEO RELEASE - BASIC .ENV
# Chỉ chứa thông tin tối thiểu để website chạy được.
# Các cấu hình storage (R2/GDrive/FTP/B2...) khách sẽ thêm trong Admin.

APP_NAME=HLSVideo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Ho_Chi_Minh

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hlsvideo
DB_USERNAME=hlsvideo_user
DB_PASSWORD=your_db_password

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# License fallback endpoints
LICENSE_VERIFY_URL=https://vlicense.hlsstorage.com/api/license/verify
LICENSE_AUTO_TRIAL_URL=https://vlicense.hlsstorage.com/api/license/auto-trial
LICENSE_INSTANCE_ID=
